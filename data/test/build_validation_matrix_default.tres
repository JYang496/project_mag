encounter_types = [{
"id": "swarm_60s",
"label": "60s Swarm Clear",
"pressure_tags": PackedStringArray("swarm", "area", "chain", "pierce"),
"primary_question": "Can the build clear dense low-HP groups before they surround the player?"
}, {
"id": "elite_high_hp",
"label": "Single High-HP Elite",
"pressure_tags": PackedStringArray("elite", "single_target", "execute"),
"primary_question": "Can the build convert focus fire into reliable elite kills?"
}, {
"id": "support_shield_core",
"label": "Support Enemy + Shield Core",
